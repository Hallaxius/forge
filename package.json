{
	"name": "@hallaxius/forge",
	"version": "1.1.0",
	"description": "A modern Git CLI with professional UX",
	"author": "hallaxius",
	"license": "MIT",
	"type": "module",
	"bin": {
		"fg": "./dist/cli.js"
	},
	"main": "./dist/cli.js",
	"types": "./dist/cli.d.ts",
	"scripts": {
		"dev": "bun --watch src/cli.ts",
		"build:version": "bun scripts/gen-version.mjs",
		"build": "bun run build:version && bun build src/cli.ts --outdir dist --target node",
		"start": "bun bin/forge.js",
		"test": "bun test",
		"lint": "biome check",
		"format": "biome format --write",
		"lint:fix": "biome check --write --unsafe",
		"prepublishOnly": "bun run build && bun test",
		"prepack": "bun run build",
		"patch": "bun version patch && bun publish",
		"minor": "bun version minor && bun publish",
		"major": "bun version major && bun publish"
	},
	"dependencies": {
		"@octokit/rest": "^21.1.0",
		"chalk": "^5.3.0",
		"commander": "^12.0.0",
		"conf": "^12.0.0",
		"diff": "^7.0.0",
		"figures": "^5.0.0",
		"isomorphic-git": "^1.38.0",
		"ora": "^8.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/diff": "^8.0.0",
		"@types/node": "^26.0.1",
		"typescript": "^5.3.0"
	},
	"files": [
		"bin",
		"dist",
		"src"
	],
	"engines": {
		"node": ">=18.0.0",
		"bun": ">=1.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hallaxius/forge.git"
	},
	"bugs": {
		"url": "https://github.com/hallaxius/forge/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/hallaxius/forge#readme",
	"keywords": [
		"git",
		"cli",
		"forge",
		"git-cli",
		"developer-tools",
		"productivity",
		"bun",
		"command-line",
		"github-api"
	]
}
